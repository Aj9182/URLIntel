# ============================================================
# Safe Browsing - Environment Variables Example
# ============================================================
# Rename this file to .env and fill in your actual values.
# Do NOT commit your actual .env file to GitHub.
# ============================================================

# Flask secret key (change this to a long random string in production)
FLASK_SECRET_KEY=your_flask_secret_key_here

# VirusTotal API Key
# Get yours at: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# Google Safe Browsing API Key
# Get yours at: https://console.cloud.google.com/apis/credentials
GOOGLE_SAFE_BROWSING_KEY=your_google_safe_browsing_api_key_here

# Postgres Database URL (Needed for Render deployment)
# Local example: postgresql://postgres:password@localhost/scans_db
# Render example: postgresql://username:password@hostname/dbname
DATABASE_URL=your_postgres_database_url_here
